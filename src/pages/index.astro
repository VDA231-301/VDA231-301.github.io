---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GetInvolvedCta from "@/components/GetInvolvedCta.astro";
import ChallengeSection from "@/components/ChallengeSection.astro";
import SolutionSection from "@/components/SolutionSection.astro";
import { getCollection } from "astro:content";
import { getUi } from "@/i18n/index";

const t = getUi("en");
const base = import.meta.env.BASE_URL;

const allArticles = await getCollection("news-en", ({ data }) => !data.draft);
const latestArticle = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title="VDA 231-301 - An Open JSON Schema for Material Data Exchange"
  description="VDA 231-301 defines a standardized JSON schema for exchanging material data across industry supply chains."
  keywords="VDA 231-301, VDA, automotive, material information, JSON schema"
  canonical="https://vda231-301.github.io/">
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      name: "VDA 231-301",
      description:
        "An open, standardized JSON schema for exchanging material data across industry supply chains.",
      url: "https://vda231-301.github.io/",
      codeRepository: "https://github.com/VDA231-301/VDA231-301",
    })}
  />

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden"
    style={`background-image: url('${base}bg-hero.svg'); background-size: cover; background-position: center;`}>
    <div class="relative z-10 mx-auto max-w-6xl px-4 pt-16 pb-24 sm:px-6 lg:px-8">
      <div class="">
        <p class="mb-4 text-xs font-semibold tracking-[0.2em] text-[#6aad85] uppercase">
          Official VDA Recommendation
        </p>
        <h1
          class="font-display mb-6 leading-none text-balance text-white"
          style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: clamp(2.75rem, 7vw, 5rem);">
          {t.home.heroSubtitle}
        </h1>

        <p class="mb-4 text-lg leading-relaxed text-white/90">
          Increasing regulatory requirements, sustainability reporting and digital validation demand
          a new level of consistency in material data exchange.
        </p>

        <ul class="mb-6 space-y-2 text-lg leading-relaxed text-white/90">
          <li class="flex items-start gap-2">
            <span class="mt-1 text-[#6aad85]">•</span>
            <span>Reduce manual re-entry and coordination effort across partners</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 text-[#6aad85]">•</span>
            <span>Increase data consistency for compliance, sustainability and audits</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 text-[#6aad85]">•</span>
            <span>Enable validated system-to-system exchange with open JSON Schema</span>
          </li>
        </ul>
        <p class="mb-10 text-lg leading-relaxed text-[#b8d9c4]">
          {t.home.heroDescription}
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`${base}validator/`}
            class="inline-block rounded border border-[#2a8a4e] bg-[#1B6B3A] px-6 py-3 text-sm font-semibold tracking-wide text-white no-underline transition-colors hover:bg-[#2a8a4e]">
            {t.home.ctaValidator}
          </a>
          <a
            href={`${base}docs/`}
            class="inline-block rounded border border-white/25 bg-transparent px-6 py-3 text-sm font-medium tracking-wide text-white no-underline transition-colors hover:bg-white/10">
            {t.home.ctaDocs}
          </a>
        </div>
      </div>
    </div>

    <!-- bottom fade -->
    <div
      class="pointer-events-none absolute right-0 bottom-0 left-0 h-16"
      style="background: linear-gradient(to bottom, transparent, #ffffff);">
    </div>
  </section>

  <!-- ── Today's reality (challenge) ──────────────────────── -->
  <ChallengeSection
    eyebrow={t.home.challengeEyebrow}
    title={t.home.challengeTitle}
    footer={t.home.challengeFooter}
    base={base}
    cards={[
      {
        num: "01",
        head: t.home.challengeManualHead,
        body: [
          t.home.challengeManualItem1,
          t.home.challengeManualItem2,
          t.home.challengeManualItem3,
        ],
        icon: "manual",
      },
      {
        num: "02",
        head: t.home.challengeCoordHead,
        body: [t.home.challengeCoordItem1, t.home.challengeCoordItem2, t.home.challengeCoordItem3],
        icon: "coordination",
      },
      {
        num: "03",
        head: t.home.challengeRiskHead,
        body: [t.home.challengeRiskItem1, t.home.challengeRiskItem2, t.home.challengeRiskItem3],
        icon: "risk",
      },
    ]}
  />

  <!-- ── The standardized answer (solution) ───────────────── -->
  <SolutionSection
    eyebrow={t.home.solutionEyebrow}
    title={t.home.solutionTitle}
    footerLead={t.home.solutionFooterLead}
    footerTail={t.home.solutionFooterTail}
    base={base}
    cards={[
      // Consistent material definition
      {
        num: "01",
        head: t.home.solutionMatHead,
        body: [t.home.solutionMatItem1, t.home.solutionMatItem2, t.home.solutionMatItem3],
        icon: "material",
      },
      // Interoperable test & measurement data
      {
        num: "02",
        head: t.home.solutionResHead,
        body: [t.home.solutionResItem1, t.home.solutionResItem2, t.home.solutionResItem3],
        icon: "results",
        chips: [t.home.solutionResChip1, t.home.solutionResChip2, t.home.solutionResChip3],
      },
      // Shared semantic understanding
      {
        num: "03",
        head: t.home.solutionShareHead,
        body: [t.home.solutionShareItem1, t.home.solutionShareItem2, t.home.solutionShareItem3],
        icon: "shared",
      },
    ]}
  />

  <!-- ── What is VDA 231-301 ───────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
      <!-- LEFT: Text -->
      <div>
        <!-- Eyebrow -->
        <div class="mb-6 flex items-center gap-4">
          <span class="block h-6 w-0.5 bg-[#0d3d2e]"></span>
          <p class="text-sm font-semibold tracking-widest text-[#0d3d2e] uppercase">
            THE VDA RECOMMENDATION
          </p>
        </div>

        <h2
          class="mb-5 text-3xl text-balance md:text-4xl"
          style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; color: #0d3d20; line-height: 1.15;">
          {t.home.whatTitle}
        </h2>

        <p class="text-vda-green mt-4 mb-6 max-w-3xl text-lg leading-relaxed font-semibold">
          {t.home.whatLead}
        </p>

        <div class="space-y-4 text-base leading-relaxed text-[#2a3a30]">
          {
            t.home.whatBody
              .trim()
              .split(/\n\s*\n/)
              .map((paragraph) => <p>{paragraph.trim()}</p>)
          }
        </div>

        <div class="mt-6 flex flex-wrap gap-5">
          <a
            href="https://www.vda.de/en/topics/automotive-industry/The-Future-of-Material-Sampling-in-Automotive-Value-Chains"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[#1B6B3A] hover:underline">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
            VDA Website
          </a>
          <a
            href="https://webshop.vda.de/VDA/en/vda-231-301-022025"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[#1B6B3A] hover:underline">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
            Official Document (VDA Webshop)
          </a>
        </div>
      </div>

      <!-- Schema node diagram -->
      <div class="relative mt-10 md:mt-0">
        <div
          class="overflow-hidden rounded-lg border border-[#d0e5d8]"
          style="background: #f5faf7;">
          <img
            src={`${base}vda231-301-modular-concept.svg`}
            alt="VDA 231-301 schema data model diagram"
            class="h-auto w-full opacity-90"
            width="600"
            height="340"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Get Involved CTA + Facts ────────────────────────── -->
  <GetInvolvedCta
    eyebrow={t.home.ctaEyebrow}
    title={t.home.ctaTitle}
    description={t.home.ctaDescription}
    roles={t.home.ctaRoles}
    primaryLabel={t.home.ctaPrimary}
    primaryHref="https://github.com/VDA231-301"
    secondaryLabel={t.home.ctaSecondary}
    secondaryHref="https://www.vda.de/en/topics/automotive-industry/The-Future-of-Material-Sampling-in-Automotive-Value-Chains"
    ctaBody={t.home.ctaBody}
    ctaQuickstart={t.home.ctaQuickstart}
    tertiaryLabel={t.home.ctaTertiary}
    tertiaryHref="https://webshop.vda.de/VDA/en/vda-231-301-022025"
    factsTitle={t.home.factsTitle}
    base={base}
    facts={[
      { label: t.home.factsVDA, icon: "official" },
      { label: t.home.factsOpenSource, icon: "opensource" },
      { label: t.home.factsSchema, icon: "json" },
      { label: t.home.factsSubschemas, icon: "modular" },
    ]}
  />

  <!-- ── Repository Overview ──────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-center gap-4">
      <span class="block h-6 w-0.5 bg-[#0d3d2e]"></span>
      <p class="text-sm font-semibold tracking-widest text-[#0d3d2e] uppercase">
        OPEN PROJECT RESOURCES
      </p>
    </div>

    <h2
      class="mb-3 text-balance"
      style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 2rem; color: #0d3d20; line-height: 1.15;">
      Repository Overview
    </h2>
    <p class="mb-8 max-w-2xl text-base leading-relaxed text-[#2a3a30]">
      VDA 231‑301 is organized into <strong>modular subschema repositories</strong>. Each subschema
      covers a dedicated functional or regulatory domain.
    </p>
    <p class="mb-6 max-w-2xl text-base leading-relaxed text-[#2a3a30]">
      Each subschema addresses a specific functional or regulatory domain and can be used
      independently or combined depending on the use case.
    </p>
    <div class="overflow-x-auto rounded-lg border border-[#d0e5d8]">
      <table class="w-full border-collapse text-left text-sm">
        <thead>
          <tr style="background: #e8f4ec;">
            <th
              class="border-b border-[#d0e5d8] px-4 py-3 font-semibold whitespace-nowrap text-[#0d3d20]">
              Subschema Repository
            </th>
            <th class="border-b border-[#d0e5d8] px-4 py-3 font-semibold text-[#0d3d20]">
              Focus (EN)
            </th>
            <th class="border-b border-[#d0e5d8] px-4 py-3 font-semibold text-[#0d3d20]">
              Fokus (DE)
            </th>
          </tr>
        </thead>
        <tbody>
          {
            [
              {
                name: "VDA 231‑300 – Generic",
                url: "https://github.com/VDA231-301/VDA231-300",
                en: "Material and surface definition in 3D-models in JT",
                de: "Material- und Oberflächendefinition in 3D-Modellen im JT",
              },
              {
                name: "VDA 231‑301 – Generic",
                url: "https://github.com/VDA231-301/VDA231-301",
                en: "Generic core definitions and reusable model elements",
                de: "Generische Basismodelle und wiederverwendbare Strukturen",
              },
              {
                name: "Substance Declaration",
                url: "https://github.com/VDA231-301/VDA_231-301__SubstanceDeclaration",
                en: "Structured substance and material composition data",
                de: "Strukturierte Stoff‑ und Materialzusammensetzungen",
              },
              {
                name: "VDA 275 – Formaldehyde",
                url: "https://github.com/VDA231-301/VDA_231-301__VDA_275",
                en: "Formaldehyde emission test data",
                de: "Formaldehyd‑Emissionsprüfungen",
              },
              {
                name: "VDA 278 – VOC / Fogging",
                url: "https://github.com/VDA231-301/VDA_231-301__VDA_278",
                en: "VOC and fogging emission test data",
                de: "VOC‑ und Fogging‑Emissionsdaten",
              },
              {
                name: "VDA 270 – Odor",
                url: "https://github.com/VDA231-301/VDA_231-301__VDA_270",
                en: "Odor assessment based on panel testing",
                de: "Geruchsprüfungen mit Panelbewertung",
              },
              {
                name: "SEP 1240",
                url: "https://github.com/VDA231-301/VDA_231-301__SEP_1240",
                en: "Odor‑relevant material requirements",
                de: "Geruchsrelevante Werkstoffanforderungen",
              },
              {
                name: "EN 10204",
                url: "https://github.com/VDA231-301/VDA_231-301__EN_10204",
                en: "Digital inspection and acceptance certificates",
                de: "Digitale Prüf‑ und Abnahmezeugnisse",
              },
            ].map((repo, i) => (
              <tr style={{ background: i % 2 === 0 ? "#ffffff" : "#f5faf7" }}>
                <td class="border-b border-[#e8f0eb] px-4 py-3 align-top font-medium whitespace-nowrap text-[#0d3d20]">
                  <a
                    href={repo.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 font-semibold text-[#1B6B3A] hover:underline">
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                      style="flex-shrink:0">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                    {repo.name}
                  </a>
                </td>
                <td class="border-b border-[#e8f0eb] px-4 py-3 align-top text-[#2a3a30]">
                  {repo.en}
                </td>
                <td class="border-b border-[#e8f0eb] px-4 py-3 align-top text-[#2a3a30]">
                  {repo.de}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="mt-5 text-sm text-[#2a3a30]">
      Detailed data models, figures and examples are provided <strong>
        within each subschema repository
      </strong>.
    </p>
  </section>

  <!-- ── Latest News ──────────────────────────────────────── -->
  {
    latestArticle && (
      <section style="background: #f5faf7; border-top: 1px solid #d0e5d8; border-bottom: 1px solid #d0e5d8;">
        <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
          <div class="mb-6 flex items-center justify-between">
            <p class="text-xs font-semibold tracking-[0.2em] text-[#1B6B3A] uppercase">
              Latest News
            </p>
            <a href={`${base}news/`} class="text-sm font-medium text-[#1B6B3A] hover:underline">
              All news →
            </a>
          </div>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
            <time class="pt-0.5 text-xs font-medium tracking-wide whitespace-nowrap text-[#5a7a65] uppercase">
              {formatDate(latestArticle.data.date)}
            </time>
            <div>
              <h2 class="mb-2 text-lg leading-snug font-semibold text-[#0d3d20]">
                <a href={`${base}news/${latestArticle.slug}/`} class="hover:underline">
                  {latestArticle.data.title}
                </a>
              </h2>
              <p class="mb-3 text-sm leading-relaxed text-[#2a3a30]">
                {latestArticle.data.summary}
              </p>
              <a
                href={`${base}news/${latestArticle.slug}/`}
                class="text-sm font-medium text-[#1B6B3A] hover:underline">
                Read more →
              </a>
            </div>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
