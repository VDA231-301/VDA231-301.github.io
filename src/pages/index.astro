---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GetInvolvedCta from "@/components/GetInvolvedCta.astro";
import ChallengeSection from "@/components/ChallengeSection.astro";
import SolutionSection from "@/components/SolutionSection.astro";
import AudiencesSection from "@/components/AudiencesSection.astro";
import SvgLightbox from "@/components/SvgLightbox.astro";
import { getCollection } from "astro:content";
import { getUi } from "@/i18n/index";

const t = getUi("en");
const base = import.meta.env.BASE_URL;

const allArticles = await getCollection("news-en", ({ data }) => !data.draft);
const sortedArticles = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestArticles = sortedArticles.slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title="VDA 231-301 - An Open JSON Schema for Material Data Exchange"
  description="VDA 231-301 defines a standardized JSON schema for exchanging material data across industry supply chains."
  keywords="VDA 231-301, VDA, automotive, material information, JSON schema"
  canonical="https://vda231-301.github.io/">
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      name: "VDA 231-301",
      description:
        "An open, standardized JSON schema for exchanging material data across industry supply chains.",
      url: "https://vda231-301.github.io/",
      codeRepository: "https://github.com/VDA231-301/VDA231-301",
    })}
  />

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero hero--dark-deep">
    <div class="shell">
      <div class="hero-grid">
        <!-- Left: copy -->
        <div class="hero-copy">
          <p class="eyebrow">Official VDA Recommendation</p>
          <h1 set:html={`${t.home.heroTitleBlack} <span class="accent">${t.home.heroTitleGreen}</span>`} />
          <p class="hero-lede">{t.home.heroDescription}</p>
          <div class="hero-cta-row">
            <a href={`${base}validator/`} class="btn btn-primary">{t.home.ctaValidator}</a>
            <a href={`${base}docs/`} class="btn btn-ghost">{t.home.ctaDocs}</a>
          </div>
          <div class="hero-stats">
            <div>
              <div class="hero-stat-label">Format</div>
              <div class="hero-stat-value">JSON Schema</div>
            </div>
            <div>
              <div class="hero-stat-label">Schemas</div>
              <div class="hero-stat-value">6+</div>
            </div>
            <div>
              <div class="hero-stat-label">License</div>
              <div class="hero-stat-value">MIT</div>
            </div>
          </div>
        </div>
        <!-- Right: visual -->
        <div class="hero-visual">
          <img
            src={`${base}graphic/hero.svg`}
            alt="VDA 231-301 data model visualization"
            width="540"
            height="540"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Today's reality (challenge) ──────────────────────── -->
  <ChallengeSection
    eyebrow={t.home.challengeEyebrow}
    title={t.home.challengeTitle}
    footer={t.home.challengeFooter}
    base={base}
    cards={[
      {
        num: "01",
        head: t.home.challengeManualHead,
        body: [
          t.home.challengeManualItem1,
          t.home.challengeManualItem2,
          t.home.challengeManualItem3,
        ],
        icon: "manual",
      },
      {
        num: "02",
        head: t.home.challengeCoordHead,
        body: [t.home.challengeCoordItem1, t.home.challengeCoordItem2, t.home.challengeCoordItem3],
        icon: "coordination",
      },
      {
        num: "03",
        head: t.home.challengeRiskHead,
        body: [t.home.challengeRiskItem1, t.home.challengeRiskItem2, t.home.challengeRiskItem3],
        icon: "risk",
      },
    ]}
  />

  <!-- ── The standardized answer (solution) ───────────────── -->
  <SolutionSection
    eyebrow={t.home.solutionEyebrow}
    title={t.home.solutionTitle}
    footerLead={t.home.solutionFooterLead}
    footerTail={t.home.solutionFooterTail}
    base={base}
    cards={[
      // Consistent material definition
      {
        num: "01",
        head: t.home.solutionMatHead,
        body: [t.home.solutionMatItem1, t.home.solutionMatItem2, t.home.solutionMatItem3],
        icon: "material",
      },
      // Interoperable test & measurement data
      {
        num: "02",
        head: t.home.solutionResHead,
        body: [t.home.solutionResItem1, t.home.solutionResItem2, t.home.solutionResItem3],
        icon: "results",
        chips: [t.home.solutionResChip1, t.home.solutionResChip2, t.home.solutionResChip3],
      },
      // Shared semantic understanding
      {
        num: "03",
        head: t.home.solutionShareHead,
        body: [t.home.solutionShareItem1, t.home.solutionShareItem2, t.home.solutionShareItem3],
        icon: "shared",
      },
    ]}
  />

  <!-- ── Modular by design ─────────────────────────────── -->
  <section class="section">
    <div class="shell">
      <div class="modular">
        <!-- Left: diagram -->
        <div>
          <img
            src={`${base}vda231-301-modular-concept.svg`}
            alt="VDA 231-301 schema data model diagram"
            style="width:100%; height:auto; border-radius:var(--radius-l); border:1px solid var(--line);"
          />
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:16px;">
            <SvgLightbox src={`${base}graphic/ai_powered_qa.png`} alt="AI-powered QA diagram" />
            <SvgLightbox src={`${base}graphic/use_case_material_sampling.svg`} alt="Material sampling use case" />
          </div>
        </div>
        <!-- Right: text -->
        <div>
          <p class="eyebrow muted">Modular by design</p>
          <h2 class="display section-title">{t.home.whatTitle}</h2>
          <p class="section-lede">{t.home.whatLead}</p>
          <div class="modular-list">
            <div class="modular-item">
              <div class="marker">01</div>
              <div>
                <h4>Open by default</h4>
                <p>JSON Schema, no license fees, no proprietary formats — built for any ecosystem.</p>
              </div>
            </div>
            <div class="modular-item">
              <div class="marker">02</div>
              <div>
                <h4>Composable</h4>
                <p>Combine the generic core with domain-specific subschemas to match your exact use case.</p>
              </div>
            </div>
            <div class="modular-item">
              <div class="marker">03</div>
              <div>
                <h4>Validation built in</h4>
                <p>Every payload can be checked against the schema in-browser or in your pipeline.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Audiences ─────────────────────────────────────── -->
  <AudiencesSection
    eyebrow={t.home.audiencesEyebrow}
    title={t.home.audiencesTitle}
    cards={[
      {
        glyph: "01",
        role: "Manufacturer",
        title: t.home.audienceMfrTitle,
        lede: t.home.audienceMfrLede,
        gains: [t.home.audienceMfrGain1, t.home.audienceMfrGain2, t.home.audienceMfrGain3],
      },
      {
        glyph: "02",
        role: "Supplier",
        title: t.home.audienceSupplierTitle,
        lede: t.home.audienceSupplierLede,
        gains: [t.home.audienceSupplierGain1, t.home.audienceSupplierGain2, t.home.audienceSupplierGain3],
      },
      {
        glyph: "03",
        role: "Test Laboratory",
        title: t.home.audienceLabTitle,
        lede: t.home.audienceLabLede,
        gains: [t.home.audienceLabGain1, t.home.audienceLabGain2, t.home.audienceLabGain3],
      },
      {
        glyph: "04",
        role: "Compliance & Quality",
        title: t.home.audienceComplianceTitle,
        lede: t.home.audienceComplianceLede,
        gains: [t.home.audienceComplianceGain1, t.home.audienceComplianceGain2, t.home.audienceComplianceGain3],
      },
    ]}
  />

  <!-- ── Get Started CTA (Steps) ───────────────────────── -->
  <GetInvolvedCta
    eyebrow={t.home.stepsEyebrow}
    title={t.home.stepsTitle}
    lede={t.home.stepsLede}
    base={base}
    steps={[
      { num: "1", head: t.home.step1Head, body: t.home.step1Body, link: t.home.step1Link, href: "https://webshop.vda.de/VDA/en/vda-231-301-022025" },
      { num: "2", head: t.home.step2Head, body: t.home.step2Body, link: t.home.step2Link, href: `${base}schemas/` },
      { num: "3", head: t.home.step3Head, body: t.home.step3Body, link: t.home.step3Link, href: `${base}validator/` },
      { num: "4", head: t.home.step4Head, body: t.home.step4Body, link: t.home.step4Link, href: `${base}docs/` },
    ]}
    primaryLabel={t.home.ctaValidator}
    primaryHref={`${base}validator/`}
    secondaryLabel={t.home.ctaDocs}
    secondaryHref={`${base}docs/`}
    tertiaryLabel="GitHub"
    tertiaryHref="https://github.com/VDA231-301"
  />

  <!-- ── Latest News ────────────────────────────────────── -->
  {
    latestArticles.length > 0 && (
      <section class="section tinted">
        <div class="shell">
          <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:48px;">
            <div>
              <p class="eyebrow">{t.home.newsEyebrow}</p>
              <h2 class="display section-title" style="margin-bottom:0">{t.home.newsTitle}</h2>
            </div>
            <a href={`${base}news/`} class="btn btn-ghost">{t.home.newsViewAll}</a>
          </div>
          <div class="news-grid">
            {latestArticles.map((article) => (
              <a href={`${base}news/${article.slug}/`} class="news-card" style="text-decoration:none;">
                <div class="news-meta">
                  <span class="tag">Release</span>
                  <span>{formatDate(article.data.date)}</span>
                </div>
                <h3>{article.data.title}</h3>
                <p>{article.data.summary}</p>
                <span class="read">{t.news.readMore} →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  const VARIANTS = [
    { id: "hero--dark-deep",   label: "Dark deep",    desc: "#0d3d20 · grid overlay" },
    { id: "hero--split",       label: "Split",        desc: "dark left / warm right" },
    { id: "hero--warm-tinted", label: "Warm tinted",  desc: "#fbfaf6 · green wash" },
    { id: "hero--forest",      label: "Forest",       desc: "#1b6b3a · SVG card" },
  ];

  const HERO_CLASSES = VARIANTS.map(v => v.id);

  function getActive(): string {
    const hero = document.querySelector(".hero");
    return HERO_CLASSES.find(c => hero?.classList.contains(c)) ?? HERO_CLASSES[0];
  }

  function applyVariant(id: string) {
    const hero = document.querySelector(".hero");
    if (!hero) return;
    hero.classList.remove(...HERO_CLASSES);
    if (id) hero.classList.add(id);
    panel.querySelectorAll<HTMLButtonElement>(".hsw-btn").forEach(btn => {
      btn.style.background = btn.dataset.variant === id ? "rgba(255,255,255,0.18)" : "transparent";
      btn.style.borderColor = btn.dataset.variant === id ? "rgba(255,255,255,0.5)" : "rgba(255,255,255,0.12)";
    });
  }

  // Build panel
  const panel = document.createElement("div");
  panel.id = "hero-switcher";
  Object.assign(panel.style, {
    position: "fixed", bottom: "24px", right: "24px", zIndex: "9999",
    background: "rgba(13,61,32,0.92)", backdropFilter: "blur(12px)",
    border: "1px solid rgba(255,255,255,0.14)", borderRadius: "12px",
    padding: "14px 16px", fontFamily: "monospace", fontSize: "11px",
    color: "rgba(255,255,255,0.55)", display: "none", minWidth: "210px",
    boxShadow: "0 8px 32px rgba(0,0,0,0.4)",
  });

  const heading = document.createElement("div");
  heading.textContent = "HERO VARIANT  ⌃⇧1";
  Object.assign(heading.style, { marginBottom: "10px", letterSpacing: "0.1em", fontSize: "10px" });
  panel.appendChild(heading);

  VARIANTS.forEach(v => {
    const btn = document.createElement("button");
    btn.className = "hsw-btn";
    btn.dataset.variant = v.id;
    btn.innerHTML = `<span style="color:#fff;font-weight:600;">${v.label}</span>
      <span style="color:rgba(255,255,255,0.4);margin-left:6px;">${v.desc}</span>`;
    Object.assign(btn.style, {
      display: "block", width: "100%", textAlign: "left", cursor: "pointer",
      background: "transparent", border: "1px solid rgba(255,255,255,0.12)",
      borderRadius: "6px", padding: "6px 10px", marginTop: "5px",
      color: "inherit", fontFamily: "monospace", fontSize: "11px",
      transition: "background 0.15s, border-color 0.15s",
    });
    btn.addEventListener("click", () => applyVariant(v.id));
    panel.appendChild(btn);
  });

  document.body.appendChild(panel);
  applyVariant(getActive());

  document.addEventListener("keydown", e => {
    if (e.ctrlKey && e.shiftKey && e.key === "!") {
      panel.style.display = panel.style.display === "none" ? "block" : "none";
      if (panel.style.display === "block") applyVariant(getActive());
    }
  });
</script>
