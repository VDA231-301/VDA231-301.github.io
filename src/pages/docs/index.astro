---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getUi } from "@/i18n/index";

const t = getUi("en");
const docs = (await getCollection("docs-en")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---

<BaseLayout title={t.docs.pageTitle} description={t.docs.pageDescription}>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-12 lg:flex-row">
      <!-- Sidebar -->
      <aside class="flex-shrink-0 lg:w-56">
        <nav aria-label="Documentation sections">
          <p class="mb-3 text-xs font-semibold tracking-widest text-gray-400 uppercase">
            Documentation
          </p>
          <ul class="space-y-1">
            {
              docs.map((doc) => (
                <li>
                  <a
                    href={`#${doc.slug}`}
                    class="block py-1 text-sm text-gray-600 no-underline transition-colors hover:text-blue-600">
                    {doc.data.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </aside>

      <!-- Content -->
      <article class="min-w-0 flex-1">
        <header class="mb-10 border-b border-gray-200 pb-6">
          <h1 class="mb-2 text-3xl font-bold text-[#1a2e4a]">{t.docs.pageTitle}</h1>
          <p class="text-gray-500">{t.docs.pageDescription}</p>
        </header>

        {
          await Promise.all(
            docs.map(async (doc) => {
              const { Content } = await doc.render();
              return (
                <section
                  id={doc.slug}
                  class="mb-12 border-b border-gray-100 pb-12 last:mb-0 last:border-0">
                  <h2 class="mb-4 text-xl font-semibold text-[#1a2e4a]">{doc.data.title}</h2>
                  <div class="prose">
                    <Content />
                  </div>
                </section>
              );
            })
          )
        }
      </article>
    </div>
  </div>
</BaseLayout>
