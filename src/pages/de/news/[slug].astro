---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getUi } from "@/i18n/index";

export async function getStaticPaths() {
  const articles = await getCollection("news-de", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const t = getUi("de");
const base = import.meta.env.BASE_URL;
const prefix = `${base}de/`;

function formatDate(date: Date) {
  return date.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout title={article.data.title} description={article.data.summary}>
  <div class="subpage-header">
    <div class="shell">
      <p class="eyebrow">
        <a href={`${prefix}news/`} style="color:var(--brand); text-decoration:none;">← {t.news.pageTitle}</a>
      </p>
      <h1 class="display" style="font-size:clamp(32px,4vw,56px);">{article.data.title}</h1>
      <p>
        {article.data.tag && <span class="tag" style="margin-right:8px;">{article.data.tag}</span>}
        <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
      </p>
    </div>
  </div>

  <div class="shell" style="padding-top:48px; padding-bottom:80px;">
    <div class="prose" style="max-width:720px;">
      <Content />
    </div>
  </div>
</BaseLayout>
