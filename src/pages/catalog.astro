---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RepositoryOverview from "@/components/RepositoryOverview.astro";
import { getUi } from "@/i18n/index";

const t = getUi("en");
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={t.catalog.pageTitle}
  description={t.catalog.pageDescription}
  canonical="https://vda231-301.github.io/catalog/">
  <div class="subpage-header">
    <div class="shell">
      <p class="eyebrow">{t.catalog.pageEyebrow}</p>
      <h1 class="display">{t.catalog.pageTitle}</h1>
      <p class="section-lede">{t.catalog.pageDescription}</p>
    </div>
  </div>

  <RepositoryOverview lang="en" base={base} />
</BaseLayout>
