---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getUi } from '@/i18n/index';

export async function getStaticPaths() {
  const articles = await getCollection('news-en', ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const t = getUi('en');
const base = import.meta.env.BASE_URL;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={article.data.title} description={article.data.summary}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="mb-8">
      <a href={`${base}news/`} class="text-sm text-blue-600 hover:underline">← {t.news.pageTitle}</a>
    </nav>

    <article>
      <header class="mb-8 pb-6 border-b border-gray-200">
        <time class="text-xs text-gray-400 font-medium uppercase tracking-wide" datetime={article.data.date.toISOString()}>
          {formatDate(article.data.date)}
        </time>
        <h1 class="text-3xl font-bold text-[#1a2e4a] mt-2 mb-3">{article.data.title}</h1>
        <p class="text-gray-500 text-base leading-relaxed">{article.data.summary}</p>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
