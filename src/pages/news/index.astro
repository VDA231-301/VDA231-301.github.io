---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getUi } from "@/i18n/index";

const t = getUi("en");
const base = import.meta.env.BASE_URL;

const allArticles = await getCollection("news-en", ({ data }) => !data.draft);
const articles = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout title={t.news.pageTitle} description={t.news.pageDescription}>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10 border-b border-gray-200 pb-6">
      <h1 class="mb-2 text-3xl font-bold text-[#1a2e4a]">{t.news.pageTitle}</h1>
      <p class="text-gray-500">{t.news.pageDescription}</p>
    </header>

    {
      articles.length === 0 ? (
        <p class="text-sm text-gray-500">{t.news.empty}</p>
      ) : (
        <ul class="divide-y divide-gray-100">
          {articles.map((article) => (
            <li class="py-8 first:pt-0">
              <time
                class="text-xs font-medium tracking-wide text-gray-400 uppercase"
                datetime={article.data.date.toISOString()}>
                {formatDate(article.data.date)}
              </time>
              <h2 class="mt-1 mb-2 text-lg font-semibold text-[#1a2e4a]">
                <a
                  href={`${base}news/${article.slug}/`}
                  class="no-underline transition-colors hover:text-blue-600">
                  {article.data.title}
                </a>
              </h2>
              <p class="mb-3 text-sm leading-relaxed text-gray-600">{article.data.summary}</p>
              <a
                href={`${base}news/${article.slug}/`}
                class="text-sm font-medium text-blue-600 hover:underline">
                {t.news.readMore} →
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
