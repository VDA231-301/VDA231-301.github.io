---
import { getUi, type Locale } from "@/i18n/index";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getUi(lang);
const base = import.meta.env.BASE_URL;

const prefix = lang === "de" ? `${base}de/` : `${base}`;

const navLinks = [
  { href: prefix, label: t.nav.home },
  { href: `${prefix}docs/`, label: t.nav.docs },
  { href: `${prefix}validator/`, label: t.nav.validator },
  { href: `${prefix}news/`, label: t.nav.news },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  const normalHref = href.replace(/\/+$/, "");
  const normalPath = currentPath.replace(/\/+$/, "");
  if (normalHref === base + "de" || normalHref === base.replace(/\/$/, "")) {
    return normalPath === normalHref;
  }
  return normalPath.startsWith(normalHref);
}
---

<header class="sticky top-0 z-50 border-b border-[#d0e5d8] bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-14 items-center justify-between">
      <!-- Logo -->
      <a
        href={prefix}
        class="group flex shrink-0 items-center gap-5 no-underline"
        aria-label="VDA 231-301 home">
        <img
          src={`${base}logos/vda-231-301-transparent.png`}
          alt="VDA 231-301 logo"
          class="h-8 w-auto"
          width="64"
          height="64"
        />
        <img
          src={`${base}logos/vda-231-300-transparent.png`}
          alt="VDA 231-300 logo"
          class="ml-1 h-8 w-auto"
          width="64"
          height="64"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden items-center gap-0.5 md:flex" aria-label="Main navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={[
                "rounded px-3.5 py-2 text-sm font-medium tracking-wide no-underline transition-colors",
                isActive(link.href)
                  ? "bg-[#e8f5ed] text-[#1B6B3A]"
                  : "text-[#2a3a30] hover:bg-[#f5faf7] hover:text-[#1B6B3A]",
              ].join(" ")}
              aria-current={isActive(link.href) ? "page" : undefined}>
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- GitHub link -->
      <a
        href="https://github.com/VDA231-301"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#2a3a30] transition-colors hover:text-[#1B6B3A]"
        aria-label="VDA 231-301 on GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z">
          </path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    class="flex gap-0.5 overflow-x-auto border-t border-[#e8f5ed] px-4 py-1.5 md:hidden"
    aria-label="Mobile navigation">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class={[
            "rounded px-3 py-1.5 text-sm font-medium whitespace-nowrap no-underline transition-colors",
            isActive(link.href)
              ? "bg-[#e8f5ed] text-[#1B6B3A]"
              : "text-[#2a3a30] hover:text-[#1B6B3A]",
          ].join(" ")}
          aria-current={isActive(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
