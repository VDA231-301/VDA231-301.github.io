---
import { getUi, type Locale } from "@/i18n/index";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getUi(lang);
const base = import.meta.env.BASE_URL;

const prefix = lang === "de" ? `${base}de/` : `${base}`;

const navLinks = [
  { href: prefix, label: t.nav.home },
  { href: `${prefix}docs/`, label: t.nav.docs },
  { href: `${prefix}validator/`, label: t.nav.validator },
  { href: `${prefix}news/`, label: t.nav.news },
  { href: `${prefix}schemas/`, label: t.schemas.nav },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  const normalHref = href.replace(/\/+$/, "");
  const normalPath = currentPath.replace(/\/+$/, "");
  if (normalHref === base + "de" || normalHref === base.replace(/\/$/, "")) {
    return normalPath === normalHref;
  }
  return normalPath.startsWith(normalHref);
}
---

<header class="nav">
  <div class="shell">
    <div class="nav-inner">
      <!-- Logo -->
      <a href={prefix} class="logo no-underline" aria-label="VDA 231-301 home">
        <span class="logo-brand">Digital material thread</span>
        <span class="logo-sep" aria-hidden="true"></span>
        <span class="logo-powered" aria-hidden="true">powered by</span>
        <img
          src={`${base}logos/vda-231-301-transparent.png`}
          alt="VDA 231-301 logo"
          style="height:32px; width:auto;"
        />
        <img
          src={`${base}logos/vda-231-300-transparent.png`}
          alt="VDA 231-300 logo"
          style="height:32px; width:auto;"
        />
      </a>

      <!-- Desktop nav links -->
      <nav class="nav-links" aria-label="Main navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`nav-link${isActive(link.href) ? " active" : ""}`}
              aria-current={isActive(link.href) ? "page" : undefined}>
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Language toggle -->
      <a href={`${base}${lang === "en" ? "de/" : ""}`} class="nav-cta" aria-label="Switch language">
        {t.lang.switch}
      </a>

      <!-- GitHub link -->
      <a
        href="https://github.com/VDA231-301"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-cta"
        aria-label="VDA 231-301 on GitHub">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z">
          </path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Mobile nav (scrollable row) -->
  <nav
    class="mobile-nav"
    aria-label="Mobile navigation"
    style="display:flex; gap:4px; overflow-x:auto; border-top:1px solid var(--line); padding:6px 20px;">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          style={`white-space:nowrap; padding:6px 12px; border-radius:8px; font-size:13px; font-weight:500; color:${isActive(link.href) ? "var(--brand-deep)" : "var(--ink-2)"}; background:${isActive(link.href) ? "var(--brand-soft)" : "transparent"}; text-decoration:none;`}
          aria-current={isActive(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const header = document.querySelector(".nav");
  if (header) {
    window.addEventListener("scroll", () => {
      header.classList.toggle("scrolled", window.scrollY > 4);
    });
  }
</script>

<style>
  .logo-brand {
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.01em;
    color: var(--color-vda-dark);
    line-height: 1;
  }
  .logo-sep {
    width: 1px;
    height: 20px;
    background: var(--line);
    flex-shrink: 0;
  }
  .logo-powered {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-4);
    line-height: 1;
    margin-right: 2px;
  }

  /* Hide mobile nav on desktop */
  @media (min-width: 961px) {
    .mobile-nav {
      display: none !important;
    }
  }
  @media (max-width: 960px) {
    .nav-links {
      display: none;
    }
    .logo-brand,
    .logo-sep,
    .logo-powered {
      display: none;
    }
    .logo {
      margin-right: auto;
    }
  }
</style>
