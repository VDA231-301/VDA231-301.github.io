---
import type { Locale } from "@/i18n/index";

interface Props {
  lang: Locale;
  base: string;
}

const { lang } = Astro.props;

const repos = [
  {
    name: "VDA 231‑300 – Generic",
    url: "https://github.com/VDA231-301/VDA231-300",
    en: "Material and surface definition in 3D-models in JT",
    de: "Material- und Oberflächendefinition in 3D-Modellen im JT",
  },
  {
    name: "VDA 231‑301 – Generic",
    url: "https://github.com/VDA231-301/VDA231-301",
    en: "Generic core definitions and reusable model elements",
    de: "Generische Basismodelle und wiederverwendbare Strukturen",
  },
  {
    name: "Substance Declaration",
    url: "https://github.com/VDA231-301/VDA_231-301__SubstanceDeclaration",
    en: "Structured substance and material composition data",
    de: "Strukturierte Stoff‑ und Materialzusammensetzungen",
  },
  {
    name: "VDA 275 – Formaldehyde",
    url: "https://github.com/VDA231-301/VDA_231-301__VDA_275",
    en: "Formaldehyde emission test data",
    de: "Formaldehyd‑Emissionsprüfungen",
  },
  {
    name: "VDA 278 – VOC / Fogging",
    url: "https://github.com/VDA231-301/VDA_231-301__VDA_278",
    en: "VOC and fogging emission test data",
    de: "VOC‑ und Fogging‑Emissionsdaten",
  },
  {
    name: "VDA 270 – Odor",
    url: "https://github.com/VDA231-301/VDA_231-301__VDA_270",
    en: "Odor assessment based on panel testing",
    de: "Geruchsprüfungen mit Panelbewertung",
  },
  {
    name: "SEP 1240",
    url: "https://github.com/VDA231-301/VDA_231-301__SEP_1240",
    en: "Odor‑relevant material requirements",
    de: "Geruchsrelevante Werkstoffanforderungen",
  },
  {
    name: "EN 10204",
    url: "https://github.com/VDA231-301/VDA_231-301__EN_10204",
    en: "Digital inspection and acceptance certificates",
    de: "Digitale Prüf‑ und Abnahmezeugnisse",
  },
];

const githubSvg = `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`;
---

<section class="section">
  <div class="shell">
    <p style="margin-bottom:32px; font-size:15px; color:var(--ink-3); max-width:680px; line-height:1.65;">
      {lang === "de"
        ? "VDA 231‑301 ist in modulare Subschema-Repositories gegliedert. Jedes Subschema deckt einen bestimmten funktionalen oder regulatorischen Bereich ab und kann unabhängig oder in Kombination eingesetzt werden."
        : "VDA 231‑301 is organized into modular subschema repositories. Each subschema covers a dedicated functional or regulatory domain and can be used independently or in combination."}
    </p>

    <div class="repo-table-wrap">
      <table class="repo-table">
        <thead>
          <tr>
            <th>{lang === "de" ? "Subschema-Repository" : "Subschema Repository"}</th>
            <th>{lang === "de" ? "Fokus (EN)" : "Focus (EN)"}</th>
            <th>{lang === "de" ? "Fokus (DE)" : "Focus (DE)"}</th>
          </tr>
        </thead>
        <tbody>
          {repos.map((repo) => (
            <tr>
              <td>
                <a href={repo.url} target="_blank" rel="noopener noreferrer" set:html={`${githubSvg} ${repo.name}`} />
              </td>
              <td>{repo.en}</td>
              <td>{repo.de}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p style="margin-top:20px; font-size:13px; color:var(--ink-3);">
      {lang === "de"
        ? "Detaillierte Datenmodelle, Abbildungen und Beispiele sind in den jeweiligen Subschema-Repositories verfügbar."
        : "Detailed data models, figures and examples are provided within each subschema repository."}
    </p>
  </div>
</section>

<style>
  .repo-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-m);
    border: 1px solid var(--line);
  }
  .repo-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    text-align: left;
  }
  .repo-table thead tr {
    background: var(--bg-tint);
  }
  .repo-table th {
    padding: 12px 16px;
    font-weight: 600;
    font-size: 13px;
    color: var(--ink-2);
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }
  .repo-table tbody tr:nth-child(even) {
    background: var(--bg-soft);
  }
  .repo-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    color: var(--ink-3);
  }
  .repo-table tbody tr:last-child td {
    border-bottom: none;
  }
  .repo-table td:first-child {
    white-space: nowrap;
  }
  .repo-table td a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
    color: var(--brand);
    text-decoration: none;
  }
  .repo-table td a:hover {
    text-decoration: underline;
  }
</style>
