---
import { getUi, type Locale } from "@/i18n/index";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getUi(lang);
const base = import.meta.env.BASE_URL;
const prefix = lang === "de" ? `${base}de/` : base;

const vdaHref =
  lang === "de"
    ? "https://www.vda.de/de/themen/automobilindustrie/werkstoffliche-Bemusterung"
    : "https://www.vda.de/en/topics/automotive-industry/The-Future-of-Material-Sampling-in-Automotive-Value-Chains";
---

<footer class="footer">
  <div class="shell">
    <div class="footer-grid">
      <!-- Col 1: brand -->
      <div>
        <img
          src={`${base}logos/vda-231-301-transparent.png`}
          alt="VDA 231-301"
          style="height:36px; width:auto; margin-bottom:16px; display:block;"
        />
        <p style="max-width:260px; line-height:1.65;">{t.footer.tagline}</p>
      </div>

      <!-- Col 2: Standard -->
      <div>
        <h5>{t.footer.colStandard}</h5>
        <ul>
          <li><a href={`${prefix}docs/`}>{t.footer.docs}</a></li>
          <li><a href={`${prefix}validator/`}>{t.footer.validator}</a></li>
          <li>
            <a href="https://github.com/VDA231-301" target="_blank" rel="noopener noreferrer">
              {t.footer.github}
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Project -->
      <div>
        <h5>{t.footer.colProject}</h5>
        <ul>
          <li><a href={`${prefix}news/`}>{t.footer.news}</a></li>
          <li><a href={`${prefix}schemas/`}>{t.footer.schemas}</a></li>
          <li><a href={vdaHref} target="_blank" rel="noopener noreferrer">{t.footer.vda}</a></li>
          <li><a href="#">{t.footer.workingGroup}</a></li>
        </ul>
      </div>

      <!-- Col 4: Resources -->
      <div>
        <h5>{t.footer.colResources}</h5>
        <ul>
          <li>
            <a href="https://webshop.vda.de/VDA/en/vda-231-301-022025" target="_blank" rel="noopener noreferrer">
              {t.footer.officialDoc}
            </a>
          </li>
          <li>
            <a href="https://www.vda.de/en/topics/automotive-industry/The-Future-of-Material-Sampling-in-Automotive-Value-Chains" target="_blank" rel="noopener noreferrer">
              {t.footer.vda300}
            </a>
          </li>
          <li>
            <a href="https://catena-x.net" target="_blank" rel="noopener noreferrer">
              {t.footer.catenaX}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{t.footer.copyright} · {t.footer.license}</span>
      <span>
        <a href={`${prefix}impress/`}>{t.footer.imprint}</a>
        {" · "}
        <a href={`${prefix}privacy/`}>{t.footer.privacy}</a>
      </span>
    </div>
  </div>
</footer>
