---
interface Card {
  num: string;
  head: string;
  body: string[];
  icon: "manual" | "coordination" | "risk";
}

interface Props {
  eyebrow: string;
  title: string;
  cards: Card[];
  footer: string;
  variant?: "white" | "tint";
  base?: string;
}

const { eyebrow, title, cards, footer } = Astro.props;

const greenAccent = "#1B6B3A";
---

<section class="section">
  <div class="shell">
    <div class="section-header">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="display section-title">{title}</h2>
    </div>

    <div class="problem-grid">
      {
        cards.map((card) => (
          <article class="p-card">
            <div class="icon">
              {card.icon === "manual" && (
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M20 12V5.74853C20 5.5894 19.9368 5.43679 19.8243 5.32426L16.6757 2.17574C16.5632 2.06321 16.4106 2 16.2515 2H4.6C4.26863 2 4 2.26863 4 2.6V21.4C4 21.7314 4.26863 22 4.6 22H11"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M8 10H16M8 6H12M8 14H11"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M17.9541 16.9394L18.9541 15.9394C19.392 15.5015 20.102 15.5015 20.5399 15.9394V15.9394C20.9778 16.3773 20.9778 17.0873 20.5399 17.5252L19.5399 18.5252M17.9541 16.9394L14.963 19.9305C14.8131 20.0804 14.7147 20.2741 14.6821 20.4835L14.4394 22.0399L15.9957 21.7973C16.2052 21.7646 16.3988 21.6662 16.5487 21.5163L19.5399 18.5252M17.9541 16.9394L19.5399 18.5252"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M16 2V5.4C16 5.73137 16.2686 6 16.6 6H20"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              {card.icon === "coordination" && (
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M7 18V17C7 14.2386 9.23858 12 12 12V12C14.7614 12 17 14.2386 17 17V18"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M1 18V17C1 15.3431 2.34315 14 4 14V14"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M23 18V17C23 15.3431 21.6569 14 20 14V14"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M12 12C13.6569 12 15 10.6569 15 9C15 7.34315 13.6569 6 12 6C10.3431 6 9 7.34315 9 9C9 10.6569 10.3431 12 12 12Z"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M4 14C5.10457 14 6 13.1046 6 12C6 10.8954 5.10457 10 4 10C2.89543 10 2 10.8954 2 12C2 13.1046 2.89543 14 4 14Z"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M20 14C21.1046 14 22 13.1046 22 12C22 10.8954 21.1046 10 20 10C18.8954 10 18 10.8954 18 12C18 13.1046 18.8954 14 20 14Z"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              {card.icon === "risk" && (
                <svg
                  width="20"
                  height="20"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M20.0429 21H3.95705C2.41902 21 1.45658 19.3364 2.22324 18.0031L10.2662 4.01533C11.0352 2.67792 12.9648 2.67791 13.7338 4.01532L21.7768 18.0031C22.5434 19.3364 21.581 21 20.0429 21Z"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                  <path
                    d="M12 9V13"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                  <path
                    d="M12 17.01L12.01 16.9989"
                    stroke={greenAccent}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
            </div>

            <div class="num">{card.num}</div>
            <h3>{card.head}</h3>
            <ul>
              {card.body.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <p
      style="margin-top:32px; font-size:14px; color:var(--ink-3); font-style:italic; max-width:720px;">
      {footer}
    </p>
  </div>
</section>
