---
interface Props {
  src: string;
  alt: string;
  thumbAlt?: string;
}

const { src, alt, thumbAlt } = Astro.props;
const id = `lb-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="svg-thumb">
  <button class="svg-thumb-btn" data-dialog={id} aria-label={`View ${alt} full size`}>
    <img src={src} alt={thumbAlt ?? alt} loading="lazy" />
    <span class="svg-thumb-overlay" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
      </svg>
    </span>
  </button>
</div>

<dialog id={id} class="svg-dialog">
  <button class="svg-dialog-close" aria-label="Close">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <img src={src} alt={alt} />
</dialog>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-dialog]").forEach((btn) => {
    const id = btn.dataset.dialog!;
    const dialog = document.getElementById(id) as HTMLDialogElement | null;
    if (!dialog) return;

    btn.addEventListener("click", () => dialog.showModal());

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog.querySelector(".svg-dialog-close")?.addEventListener("click", () => dialog.close());
  });
</script>

<style>
  .svg-thumb {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--line);
  }
  .svg-thumb-btn {
    display: block;
    width: 100%;
    background: var(--bg-elev);
    border: none;
    padding: 0;
    cursor: zoom-in;
    position: relative;
  }
  .svg-thumb-btn img {
    width: 100%;
    height: 160px;
    object-fit: contain;
    display: block;
    padding: 12px;
  }
  .svg-thumb-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 26, 20, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: background 0.2s;
  }
  .svg-thumb-btn:hover .svg-thumb-overlay {
    background: rgba(15, 26, 20, 0.35);
  }
  .svg-dialog {
    max-width: min(90vw, 1000px);
    max-height: 90vh;
    width: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    padding: 32px;
    background: var(--bg-elev);
    position: relative;
    overflow: auto;
    box-shadow: var(--shadow-3);
  }
  .svg-dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }
  .svg-dialog img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  .svg-dialog-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 6px;
    cursor: pointer;
    color: var(--ink-3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .svg-dialog-close:hover {
    background: var(--bg-tint);
    color: var(--ink);
  }
</style>
