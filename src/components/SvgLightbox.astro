---
interface Props {
  src: string;
  alt: string;
  thumbAlt?: string;
}

const { src, alt, thumbAlt } = Astro.props;
---

<a href={src} class="glightbox svg-thumb" data-gallery="diagrams" data-title={alt}>
  <img src={src} alt={thumbAlt ?? alt} loading="lazy" />
  <span class="svg-thumb-overlay" aria-hidden="true">
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2">
      <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"></path>
    </svg>
  </span>
</a>

<script>
  import GLightbox from "glightbox";
  import "glightbox/dist/css/glightbox.min.css";

  GLightbox({ selector: ".glightbox", touchNavigation: true, loop: false });
</script>

<style>
  .svg-thumb {
    position: relative;
    display: block;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    text-decoration: none;
  }
  .svg-thumb img {
    width: 100%;
    height: 160px;
    object-fit: contain;
    display: block;
    padding: 12px;
  }
  .svg-thumb-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 26, 20, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: background 0.2s;
  }
  .svg-thumb:hover .svg-thumb-overlay {
    background: rgba(15, 26, 20, 0.35);
  }
  .svg-thumb:hover {
    text-decoration: none;
  }
</style>
