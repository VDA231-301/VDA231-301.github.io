---
interface Card {
  num: string;
  head: string;
  body: string[];
  icon: "material" | "results" | "shared";
  chips?: string[];
}

interface Props {
  eyebrow: string;
  title: string;
  cards: Card[];
  footerLead: string;
  footerTail: string;
  variant?: "white" | "tint";
  base?: string;
}

const { eyebrow, title, cards, footerLead, footerTail } = Astro.props;

const accent = "#1B6B3A";
---

<section class="section tinted">
  <div class="shell">
    <div class="section-header">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="display section-title">{title}</h2>
    </div>

    <div class="pillars">
      {
        cards.map((card) => (
          <div class="pillar">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:8px;">
              <p class="num">{card.num}</p>
              <span style={`color:${accent};`}>
                {card.icon === "material" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M4 3C4 8.625 12 12 12 12C12 12 20 15.375 20 21"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M20 3C20 8.625 12 12 12 12C12 12 4 15.375 4 21"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M8 6L19 6"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M8 18H19"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M11 9H16.5"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M11 15H16.5"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                {card.icon === "results" && (
                  <svg
                    width="22"
                    height="22"
                    stroke-width="1.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg">
                    <rect
                      x="3"
                      y="2"
                      width="7"
                      height="5"
                      rx="0.6"
                      stroke={accent}
                      stroke-width="1.5"
                    />
                    <rect
                      x="8.5"
                      y="17"
                      width="7"
                      height="5"
                      rx="0.6"
                      stroke={accent}
                      stroke-width="1.5"
                    />
                    <rect
                      x="14"
                      y="2"
                      width="7"
                      height="5"
                      rx="0.6"
                      stroke={accent}
                      stroke-width="1.5"
                    />
                    <path
                      d="M6.5 7V10.5C6.5 11.6046 7.39543 12.5 8.5 12.5H15.5C16.6046 12.5 17.5 11.6046 17.5 10.5V7"
                      stroke={accent}
                      stroke-width="1.5"
                    />
                    <path d="M12 12.5V17" stroke={accent} stroke-width="1.5" />
                  </svg>
                )}
                {card.icon === "shared" && (
                  <svg
                    width="22"
                    height="22"
                    stroke-width="1.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M2.5 12.5L8 14.5L7 18L8 21"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M17 20.5L16.5 18L14 17V13.5L17 12.5L21.5 13"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M19 5.5L18.5 7L15 7.5V10.5L17.5 9.5H19.5L21.5 10.5"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M2.5 10.5L5 8.5L7.5 8L9.5 5L8.5 3"
                      stroke={accent}
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
              </span>
            </div>
            <h3>{card.head}</h3>
            <p style="font-size:14px; color:var(--ink-3); margin-bottom:12px;">
              {card.body.join(" · ")}
            </p>
            {card.chips && card.chips.length > 0 && (
              <div class="meta">
                {card.chips.map((chip) => (
                  <span class="chip">{chip}</span>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </div>

    <p style="margin-top:32px; font-size:14px; color:var(--ink-3); max-width:720px;">
      <strong style={`color:${accent};`}>VDA 231‑300</strong>
      {footerLead}
      {" "}<strong style={`color:${accent};`}>VDA 231‑301</strong>
      {footerTail}
    </p>
  </div>
</section>
