---
interface Card {
  num: string;
  head: string;
  body: string[];
  icon: 'material' | 'results' | 'shared';
  chips?: string[];
}

interface Props {
  eyebrow: string;
  title: string;
  cards: Card[];
  footerLead: string;
  footerTail: string;
  variant?: 'white' | 'tint';
  base?: string;
}

const { eyebrow, title, cards, footerLead, footerTail, variant = 'tint', base = '/' } = Astro.props;

const accent = '#1B6B3A';

const sectionStyle = variant === 'tint'
  ? `background: #f5faf7; background-image: url('${base}bg-section.svg'); background-size: 32px 32px; border-top: 1px solid #d0e5d8; border-bottom: 1px solid #d0e5d8;`
  : '';
 const cardStyle = variant === 'tint'
  ? `background: white`
  : `background: url('${base}bg-section.svg') no-repeat center; background-size: cover;`;
---

<section style={sectionStyle}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="shrink-0 w-0.5 h-6 rounded-full" style={`background: ${accent};`} aria-hidden="true"></span>
      <p style={`font-family: 'Barlow Condensed', sans-serif; font-weight: 600; font-size: 1rem; letter-spacing: 0.2em; text-transform: uppercase; color: ${accent};`}>
        {eyebrow}
      </p>
    </div>
    <h2
      class="mb-10 text-balance max-w-3xl"
      style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 2rem; color: #0d3d20; line-height: 1.15;"
    >
      {title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {cards.map((card) => (
        <article class="relative rounded-lg border border-[#d0e5d8] p-6 overflow-hidden" style={cardStyle}>
          <span
            class="absolute inset-x-0 top-0 h-0.5"
            style={`background: ${accent};`}
            aria-hidden="true"
          ></span>

          <div class="flex items-start justify-between mb-5">
            <span
              style={`font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.25rem; color: ${accent}; letter-spacing: 0.05em;`}
            >
              {card.num}
            </span>
            <span aria-hidden="true">
              {card.icon === 'material' && (
               <svg width="24px" height="24px" viewBox="0 0 24 24" stroke-width="1.5" fill="none" xmlns="http://www.w3.org/2000/svg" color="#000000">
                <path d="M4 3C4 8.625 12 12 12 12C12 12 20 15.375 20 21" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M20 3C20 8.625 12 12 12 12C12 12 4 15.375 4 21" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M8 6L19 6" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 18H19" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M11 9H16.5" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M11 15H16.5" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              )}
              {card.icon === 'results' && (
              <svg width="24px" height="24px" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="#000000">
                <rect x="3" y="2" width="7" height="5" rx="0.6" stroke={accent} stroke-width="1.5" stroke-width="1.5"></rect>
                <rect x="8.5" y="17" width="7" height="5" rx="0.6" stroke={accent} stroke-width="1.5" stroke-width="1.5"></rect>
                <rect x="14" y="2" width="7" height="5" rx="0.6" stroke={accent} stroke-width="1.5" stroke-width="1.5"></rect>
                <path d="M6.5 7V10.5C6.5 11.6046 7.39543 12.5 8.5 12.5H15.5C16.6046 12.5 17.5 11.6046 17.5 10.5V7" stroke={accent} stroke-width="1.5"></path>
                <path d="M12 12.5V17" stroke={accent} stroke-width="1.5"></path></svg>
              )}
              {card.icon === 'shared' && (
               <?xml version="1.0" encoding="UTF-8"?><svg width="24px" height="24px" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="#000000"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M2.5 12.5L8 14.5L7 18L8 21" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M17 20.5L16.5 18L14 17V13.5L17 12.5L21.5 13" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M19 5.5L18.5 7L15 7.5V10.5L17.5 9.5H19.5L21.5 10.5" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M2.5 10.5L5 8.5L7.5 8L9.5 5L8.5 3" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              )}
            </span>
          </div>

          <h3
            class="mb-2"
            style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.35rem; color: #0d3d20; line-height: 1.2;"
          >
            {card.head}
          </h3>
          <ul class="text-[#2a3a30] text-sm leading-relaxed space-y-1 list-none">
            {card.body.map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1.5 shrink-0 w-1 h-1 rounded-full" style={`background: ${accent};`} aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>

          {card.chips && card.chips.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-1.5">
              {card.chips.map((chip) => (
                <span
                  class="inline-block text-xs font-medium px-2 py-0.5 rounded-full border"
                  style={`color: ${accent}; border-color: #b8d9c4; background: #eef7f1;`}
                >
                  {chip}
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>

    <p class="mt-10 text-[#0d3d20] leading-relaxed max-w-3xl text-base">
      <span class="font-semibold" style={`color: ${accent};`}>VDA 231‑300</span> {footerLead}
      <span class="font-semibold" style={`color: ${accent};`}>VDA 231‑301</span> {footerTail}
    </p>
  </div>
</section>
