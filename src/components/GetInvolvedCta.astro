---
interface Step {
  num: string;
  head: string;
  body: string;
  link: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lede: string;
  steps: Step[];
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
  tertiaryLabel: string;
  tertiaryHref: string;
  base?: string;
}

const {
  eyebrow,
  title,
  lede,
  steps,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  tertiaryLabel,
  tertiaryHref,
} = Astro.props;
---

<section class="section">
  <div class="shell">
    <div class="cta">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="display" set:html={title} />
      <p class="section-lede">{lede}</p>

      <div class="steps">
        {
          steps.map((step) => (
            <div class="step">
              <div class="step-num">{step.num}</div>
              <h4>{step.head}</h4>
              <p>{step.body}</p>
              <a href={step.href}>{step.link}</a>
            </div>
          ))
        }
      </div>

      <div class="cta-actions">
        <a href={primaryHref} class="btn btn-primary">{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-ghost">{secondaryLabel}</a>
        <a href={tertiaryHref} class="btn btn-ghost">{tertiaryLabel}</a>
      </div>
    </div>
  </div>
</section>
