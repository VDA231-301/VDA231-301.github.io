---
interface Step {
  num: string;
  head: string;
  body: string;
  link: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lede: string;
  steps: Step[];
  base?: string;
}

const { eyebrow, title, lede, steps } = Astro.props;
---

<section class="section">
  <div class="shell">
    <div class="cta">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="display" set:html={title} />
      <p class="section-lede">{lede}</p>

      <div class="steps">
        {
          steps.map((step) => (
            <div class="step">
              <div class="step-num">{step.num}</div>
              <h4>{step.head}</h4>
              <p>{step.body}</p>
              <a href={step.href}>{step.link}</a>
            </div>
          ))
        }
      </div>

      <div class="cta-actions">
        <a
          href="https://github.com/VDA231-301"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer">
          GitHub
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            style="vertical-align:-1px; margin-left:6px;">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
